{
    "extends": "../../.eslintrc.react.json",
    "plugins": [
        "jest"
    ],
    "rules": {        
        "jsx-a11y/no-static-element-interactions": "off",
        "filenames/match-regex": [2, "^[a-z-\\.]+$"],
        "no-unused-vars": "off",
        "max-len": "off"
    },
    "env": {
      "jest": true
    }
}
